# Variáveis de ambiente — copie para .env e preencha os valores locais.
# Em produção, configure no painel Cloudflare Pages → Settings → Environment variables.

# ID do Meta Pixel (público — pode aparecer no HTML)
PUBLIC_META_PIXEL_ID=

# Token de acesso da Meta Conversions API (secreto — nunca commitado)
META_CAPI_TOKEN=

# Segredo compartilhado KROB (secreto)
CAPI_SHARED_SECRET=

# Código de teste do Events Manager (opcional — só para debug/staging)
# META_TEST_EVENT_CODE=
