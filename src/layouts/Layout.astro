---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Vagas limitadas. Descontos de até 80% em Shopee, Mercado Livre, Amazon e muito mais, direto no seu WhatsApp.',
  ogImage = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// PUBLIC_META_PIXEL_ID é público (aparece no HTML de qualquer site com Pixel Meta).
// Fallback hardcoded porque o Cloudflare Workers resolve env vars no runtime,
// mas import.meta.env é resolvido no build time (onde a var não está disponível).
const pixelId = import.meta.env.PUBLIC_META_PIXEL_ID ?? '1682851872728506';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/imagens/ofertas-br-ico.png" />
    <link rel="apple-touch-icon" href="/imagens/ofertas-br-ico.png" />

    <!-- DNS prefetch para recursos externos críticos -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />

    <!-- Preconnect para fontes (só os necessários) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!--
      Fonte Inter — carregamento NÃO bloqueante:
      1. rel="preload" inicia download cedo
      2. media="print" impede bloqueio de renderização
      3. onload troca para "all" após carregamento
      4. noscript garante fallback sem JS
      Pesos reduzidos: 700;800;900 (sem 400 e 600 — não usados)
    -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@700;800;900&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@700;800;900&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@700;800;900&display=swap"
      />
    </noscript>

    <!-- KROB — krobt.js síncrono (deve rodar antes do Pixel para expor window.krobTracker) -->
    <script src="/js/krobt.js" is:inline></script>

    <!-- Meta Pixel — init + ViewContent cliente/servidor com dedup via eventID compartilhado -->
    <script define:vars={{ pixelId }} is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');

      // Init com external_id first-party (cookie _krob_eid já setado pelo krobt.js)
      fbq('init', pixelId, {
        external_id: (document.cookie.match(/(?:^|;\s*)_krob_eid=([^;]*)/) || [])[1] || ''
      });

      // ViewContent cliente — eventID compartilhado com CAPI para deduplicação
      fbq('track', 'ViewContent', {
        content_name: 'Grupo VIP OFERTAS BR',
        content_category: 'lead_magnet'
      }, { eventID: window.krobTracker.pageViewEventId });

      // ViewContent servidor — mesmo eventID, Meta deduplica automaticamente
      window.krobTracker.sendEvent('ViewContent', {
        content_name: 'Grupo VIP OFERTAS BR',
        content_category: 'lead_magnet'
      }, { eventId: window.krobTracker.pageViewEventId });
    </script>
    <noscript>
      <img height="1" width="1" style="display:none"
        src={`https://www.facebook.com/tr?id=${pixelId}&ev=PageView&noscript=1`}
      />
    </noscript>

    <!-- Google Tag Manager — async, não bloqueia renderização -->
    <script>
      window.dataLayer = window.dataLayer || [];
    </script>
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-5CJNV5G');</script>
  </head>
  <body>
    <!-- GTM noscript — imediatamente após <body> -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-5CJNV5G"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>

    <slot />
  </body>
</html>
